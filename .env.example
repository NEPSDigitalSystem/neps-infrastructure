# ═════════════════════════════════════════════════════════════════════════════
# NEPS Infrastructure — Environment Variables Example
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# WARNING: Never commit .env to git — it contains secrets!
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 1: Application Configuration
# ═════════════════════════════════════════════════════════════════════════════

# Application metadata
APP_NAME=NEPS Digital
APP_ENV=development
DEBUG=true

# Environment mode: development | staging | production
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 2: REDCap Integration
# ═════════════════════════════════════════════════════════════════════════════

# ── Option 1: Standalone Mock REDCap API (Render-hosted) ──
REDCAP_API_URL=https://mock-redcap-service.onrender.com/api
REDCAP_API_TOKEN=mock_token_neps_2025
REDCAP_MOCK_ENABLED=true

# ── Option 2: Embedded Mock REDCap API (runs inside neps-backend) ──
# Uncomment these to use the embedded mock instead of Render:
# REDCAP_API_URL=http://neps-backend:8000/api/redcap
# REDCAP_API_TOKEN=mock_token_for_development_only
# REDCAP_MOCK_ENABLED=true

# ── Option 3: Real REDCap API (production) ──
# Uncomment these when you have real REDCap credentials:
# REDCAP_API_URL=https://kcird.org/api/
# REDCAP_API_TOKEN=your_real_redcap_api_token_here
# REDCAP_MOCK_ENABLED=false

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 3: Security & Secrets
# ═════════════════════════════════════════════════════════════════════════════

# Secret key for encryption, JWT signing, sessions, etc.
# CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# NextAuth.js / Auth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-another-long-random-secret

# Grafana admin password
GRAFANA_PASSWORD=neps-devops2026

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 4: Database (PostgreSQL)
# ═════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection settings
POSTGRES_USER=neps
POSTGRES_PASSWORD=neps_password
POSTGRES_DB=neps_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full database URL (used by some services)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://neps:neps_password@postgres:5432/neps_db

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 5: Redis Cache & Sessions
# ═════════════════════════════════════════════════════════════════════════════

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# Alternative Redis settings (if needed)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 6: Docker & Deployment
# ═════════════════════════════════════════════════════════════════════════════

# Docker image tag for production builds
IMAGE_TAG=latest

# Docker registry settings
DOCKER_REGISTRY=ghcr.io
DOCKER_ORG=nepsdigitalsystem

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 7: Monitoring & Alerting
# ═════════════════════════════════════════════════════════════════════════════

# Prometheus settings
PROMETHEUS_RETENTION=30d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Alertmanager settings
# Discord webhook URL for alerts (see docs/discord-alerts-setup.md)
ALERTMANAGER_DISCORD_WEBHOOK_URL=
# Email settings (optional)
ALERTMANAGER_EMAIL_TO=
ALERTMANAGER_EMAIL_FROM=

# Loki settings
LOKI_RETENTION=720h

# ═════════════════════════════════════════════════════════════════════════════
# SECTION 8: Feature Flags
# ═════════════════════════════════════════════════════════════════════════════

# Enable/disable specific features
ENABLE_ML_AI=false
ENABLE_DATA_PLATFORM=false
ENABLE_ADVANCED_ANALYTICS=false

# ═════════════════════════════════════════════════════════════════════════════
# END OF FILE
# ═════════════════════════════════════════════════════════════════════════════
