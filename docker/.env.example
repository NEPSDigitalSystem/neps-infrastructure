# ─── NEPS Infrastructure — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# ─── REDCap Integration ────────────────────────────────────────────────────
# Option 1: Use Standalone Mock REDCap API (hosted on Render)
REDCAP_API_URL=https://mock-redcap-service.onrender.com/api
REDCAP_API_TOKEN=mock_token_neps_2025

# Option 2: Use Embedded Mock REDCap API (runs inside neps-backend)
# REDCAP_API_URL=http://neps-backend:8000/api/redcap
# REDCAP_API_TOKEN=mock_token_for_development_only
# REDCAP_MOCK_ENABLED=true

# When real REDCap credentials are available:
# REDCAP_API_URL=https://kcird.org/api/
# REDCAP_API_TOKEN=your_real_redcap_api_token_here
# REDCAP_MOCK_ENABLED=false

# ─── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
GRAFANA_PASSWORD=neps-devops2026

# ─── Application Settings ──────────────────────────────────────────────────
APP_NAME=NEPS Digital
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=neps
POSTGRES_PASSWORD=neps_password
POSTGRES_DB=neps_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Image Tag (for production) ────────────────────────────────────────────
IMAGE_TAG=latest

# ─── Environment ───────────────────────────────────────────────────────────
# Options: development | staging | production
ENVIRONMENT=development
