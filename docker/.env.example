# ─── NEPS Infrastructure — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# ─── REDCap Integration ────────────────────────────────────────────────────
REDCAP_API_URL=https://redcap.knust.edu.gh/api/
REDCAP_API_TOKEN=your_redcap_api_token_here

# ─── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# ─── Monitoring ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-this-grafana-password

# ─── Environment ───────────────────────────────────────────────────────────
# Options: development | staging | production
ENVIRONMENT=development
